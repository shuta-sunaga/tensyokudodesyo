# ===== ローカル開発用環境変数 =====
# このファイルを .env にコピーして値を埋める。.env はリポジトリにコミットしないこと。

# サーバー
PORT=3001
NODE_ENV=development
USE_LOCAL_SECRETS=true

# Lark
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxx
LARK_APP_TOKEN=bascn1234567890abcdef
LARK_TABLE_ID=tblXXXXXXXXXXXX

# Cloudflare Turnstile (https://dash.cloudflare.com/?to=/:account/turnstile)
# 開発用テストキー: 1x0000000000000000000000000000000AA (常に成功)
# 本番用は事前にダッシュボードでサイトを登録して取得
TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# AWS SES (ローカルでも実SESを使う場合は AWS 認証情報が必要)
AWS_REGION=ap-northeast-1
SES_FROM_ADDRESS=noreply@tensyokudodesyo.com
SES_REPLY_TO=info@tensyokudodesyo.com
SES_CONFIG_SET=

# AWS 認証 (SES送信に必要)
# プロファイルを使う場合は以下不要、~/.aws/credentials を使う
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
